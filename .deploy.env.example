# SSH host (or IP) of the production server
DEPLOY_HOST=your-server.example.com

# SSH username (must have passwordless sudo for `systemctl restart`)
DEPLOY_USER=yury

# SSH port (default: 22)
DEPLOY_PORT=22

# Absolute path to the project on the server
DEPLOY_PATH=/home/yury/price_tracker

# Branch to deploy (default: main)
DEPLOY_BRANCH=main

# Optional: path to SSH private key (e.g., ~/.ssh/id_ed25519)
# Leave empty to use ssh-agent / default keys.
DEPLOY_SSH_KEY=
